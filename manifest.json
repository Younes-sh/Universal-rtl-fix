{
  "manifest_version": 3,
  "name": "Universal RTL Language Fix",
  "version": "1.1.0",
  "description": "__MSG_extDescription__",
  "author": "Younes SHEIKHLAR",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_start"
    }
  ],
  "default_locale": "en"
}
